# 开发环境镜像，使用 uv 管理依赖（替代原来的 pip + requirements.txt 流程）
FROM python:3.11-slim

WORKDIR /app

# 系统依赖：编译 mysqlclient/pdfbox 等扩展、健康检查用的 nc/curl
RUN apt-get update && apt-get install -y \
  build-essential \
  default-libmysqlclient-dev \
  pkg-config \
  netcat-traditional \
  curl \
  && rm -rf /var/lib/apt/lists/*

# 安装 uv（一次性下载预编译二进制，体积小、速度快）
COPY --from=ghcr.io/astral-sh/uv:0.4.30 /uv /usr/local/bin/uv

# 让 uv 与系统 Python 同源，避免重复下载解释器
ENV UV_SYSTEM_PYTHON=1
ENV UV_COMPILE_BYTECODE=1
ENV UV_LINK_MODE=copy

# 先只拷依赖元数据，让 docker layer cache 命中
COPY pyproject.toml uv.lock ./

# 用 uv.lock 锁定的版本同步依赖到 /app/.venv
# --frozen 不修改锁文件；--no-install-project 只装依赖、不打包当前项目
RUN uv sync --frozen --no-install-project

# 后续才拷业务代码，避免源码改动导致依赖层失效
COPY entrypoint.sh ./
RUN chmod +x entrypoint.sh

COPY . .

# 用户文件上传目录
RUN mkdir -p uploads

# 让 uv 创建的虚拟环境进入 PATH，这样直接 alembic / uvicorn 就能用
ENV PYTHONPATH=/app
ENV PATH="/app/.venv/bin:${PATH}"
ENV ENVIRONMENT=development

ENTRYPOINT ["./entrypoint.sh"]
