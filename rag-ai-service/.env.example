# rag-ai-service 本地环境变量样例
# 用法：cp rag-ai-service/.env.example rag-ai-service/.env  然后按需修改
#
# 真实密钥（OPENAI_API_KEY 等）请直接写到 .env，绝对不要提交到 git
# 该文件只放占位/默认值，按 US-002 的验收要求覆盖了 mysql/chromadb/minio/nacos 五项

# ====== 应用 ======
APP_PORT=8000
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ====== MySQL ======
# 本地直连用 127.0.0.1；docker compose 内会自动用服务名 db 覆盖
MYSQL_SERVER=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=ragwebui
MYSQL_PASSWORD=ragwebui
MYSQL_DATABASE=ragwebui

# ====== ChromaDB（向量库） ======
# docker-compose.dev.yml 把 chromadb 暴露在宿主 8001，容器内端口仍是 8000
CHROMA_DB_HOST=127.0.0.1
CHROMA_DB_PORT=8001

# ====== MinIO（对象存储） ======
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=documents

# ====== Nacos ======
NACOS_SERVER_ADDR=127.0.0.1:8848
NACOS_NAMESPACE=
NACOS_GROUP=DEFAULT_GROUP
NACOS_DATA_ID=rag-ai-service.yaml
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos

# ====== LLM / Embedding（US-003 会处理） ======
# Chat / Embedding provider，可选：openai / deepseek / ollama / dashscope
CHAT_PROVIDER=openai
EMBEDDINGS_PROVIDER=openai

# OpenAI（如果 provider=openai 必填）
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4
OPENAI_EMBEDDINGS_MODEL=text-embedding-ada-002

# DashScope（阿里云通义千问，可选）
DASH_SCOPE_API_KEY=
DASH_SCOPE_EMBEDDINGS_MODEL=

# DeepSeek（可选）
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Ollama（本地模型，可选）
OLLAMA_API_BASE=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:7b
OLLAMA_EMBEDDINGS_MODEL=nomic-embed-text

# ====== 向量库类型 ======
VECTOR_STORE_TYPE=chroma
QDRANT_URL=http://localhost:6333
QDRANT_PREFER_GRPC=true
